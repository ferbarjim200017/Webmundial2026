# =====================================================================
#  Webmundial 2026 — Variables de entorno
#  Copia este archivo como .env.local y rellena con tus datos de Firebase.
#  En Vercel: Project Settings > Environment Variables (mismos nombres).
# =====================================================================

# ---- Firebase Web SDK (públicas, prefijo NEXT_PUBLIC_) ----
# Firebase Console > Configuración del proyecto > Tus apps > SDK config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- App ----
NEXT_PUBLIC_APP_NAME="Mundial 2026"
# Correos que tendrán rol de administrador automáticamente al iniciar sesión.
# Separados por comas.
NEXT_PUBLIC_ADMIN_EMAILS="ferbarjim2000@gmail.com"
